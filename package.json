{
	"name": "onesown",
	"version": "1.0.0",
	"private": true,
	"description": "A Room of One's Own — one draft, eight rooms. A notepad that swaps the app around your words.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/emit-deployment-metadata.mjs",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "pnpm test:unit",
		"test:unit": "node --experimental-strip-types --test tests/markers.test.ts tests/palette.test.ts tests/headers.test.mjs tests/verify-dirty.test.mjs",
		"test:e2e": "node tests/e2e.mjs",
		"deploy": "pnpm build && wrangler deploy"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.69.2",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/vite": "4.3.2",
		"@types/node": "22.20.1",
		"playwright-core": "1.61.1",
		"svelte": "5.56.4",
		"svelte-check": "4.7.2",
		"tailwindcss": "4.3.2",
		"typescript": "5.9.3",
		"vite": "8.1.4",
		"wrangler": "4.110.0"
	},
	"engines": {
		"node": ">=22.18"
	},
	"packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
