# Served by Cloudflare Workers static assets (this file itself is parsed, not
# served). The script/style/img/connect CSP is emitted per-page by SvelteKit as
# a <meta> tag with hashes (svelte.config.js); frame-ancestors is only valid as
# a header, so it lives here.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

# Content-hashed assets never change — cache forever.
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable
